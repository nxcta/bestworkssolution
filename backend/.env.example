PORT=3847
NODE_ENV=production

# Comma-separated list of browser origins allowed to call the API (required for cross-origin booking).
# Example: https://yourdomain.com,https://your-app.up.railway.app
# Leave empty in development to allow all; in production empty means same-origin only.
ALLOWED_ORIGINS=

BUSINESS_TZ=Asia/Manila
TEAM_NOTIFY_EMAIL=bestworkssolutions@gmail.com
RESEND_API_KEY=
RESEND_FROM=noreply@your-verified-domain.com

# Long random secret. Never commit real value. Used as Bearer token for admin API + UI.
ADMIN_TOKEN=change-me-to-a-long-random-string

# Optional: HTTP Basic for loading /admin/* pages only (browser login once per session).
# API calls use Bearer ADMIN_TOKEN only — no Basic on /api/* (avoids popup loops on Refresh/Export).
ADMIN_BASIC_USER=
ADMIN_BASIC_PASS=
