PORT=3847
NODE_ENV=production

# Comma-separated list of browser origins allowed to call the API (required for cross-origin booking).
# Example: https://yourdomain.com,https://your-app.up.railway.app
# Leave empty in development to allow all; in production empty means same-origin only.
ALLOWED_ORIGINS=

BUSINESS_TZ=Asia/Manila
TEAM_NOTIFY_EMAIL=bestworkssolutions@gmail.com
RESEND_API_KEY=
RESEND_FROM=noreply@your-verified-domain.com

# Long random secret. Never commit real value. Used as Bearer token for admin API + UI.
ADMIN_TOKEN=change-me-to-a-long-random-string

# Optional: HTTP Basic for loading /admin/* pages only (browser login once per session).
# API calls use Bearer ADMIN_TOKEN only — no Basic on /api/* (avoids popup loops on Refresh/Export).
ADMIN_BASIC_USER=
ADMIN_BASIC_PASS=

# Calendly: create a webhook pointing to POST https://<your-render-host>/webhooks/calendly (events: invitee.created, invitee.canceled).
# Paste the webhook signing secret from Calendly (often shown with a optional whsec_ prefix — both formats work).
CALENDLY_WEBHOOK_SIGNING_KEY=
# DEV ONLY — accept unsigned Calendly webhooks if set truthy (1/true/yes/on).
CALENDLY_SKIP_VERIFY=
# Rolling window length (days, max 90) used for /api/admin/metrics charts and KPI series data in /api/bookings/admin.
METRICS_DAYS=14

# Optional webhook rate limit defaults (milliseconds window, max events per IP per window).
# WEBHOOK_WINDOW_MS=
# WEBHOOK_MAX_PER_WINDOW=
